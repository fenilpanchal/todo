



pipeline {
    agent any

    environment {
        SONARQUBE = 'SonarQube'
    }

    parameters {
        string(name: 'FRONTEND_PORT', defaultValue: '', description: 'Frontend Port')
        string(name: 'BACKEND_PORT', defaultValue: '', description: 'Backend Port')
    }

    stages {

        stage('Show Ports') {
            steps {
                echo "Frontend Port: ${params.FRONTEND_PORT}"
                echo "Backend Port: ${params.BACKEND_PORT}"
            }
        }
							
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONARQUBE}") {
                    sh 'sonar-scanner'
                }
            }
        }

        stage('Quality Gate Check') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
  
    }
}






