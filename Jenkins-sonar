

pipeline {
    agent any

    parameters {
        gitParameter(
            name: 'BRANCH_NAME',
            type: 'PT_BRANCH',
            defaultValue: 'main',
            description: 'Select Git Branch',
            branchFilter: '.*'
        )
    }

    environment {
        SONARQUBE = 'sonar-J'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: "${params.BRANCH_NAME.split('/').last()}",
                    url: 'https://github.com/fenilpanchal/todo.git'
            }
        }

        stage('Sonar Scan') {
            steps {
                withSonarQubeEnv("${SONARQUBE}") {
                    sh 'sonar-scanner'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Deploy') {
            steps {
                echo "Code Passed Quality Gate"
            }
        }
    }
}

