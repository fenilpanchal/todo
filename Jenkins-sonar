

pipeline {
    agent any

    environment {
        SONARQUBE = 'SonarQube'
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/fenilpanchal/todo.git'
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv("${SONARQUBE}") {
                    sh 'sonar-scanner'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Success Stage') {
            steps {
                echo "Code is CLEAN "
            }
        }
    }
}



